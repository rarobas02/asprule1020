                                var permitFileUrl = BuildAttachmentUrl(register?.Id, "bus_perm", register?.EstBisPermitFile);
                            }
                            @if (string.IsNullOrEmpty(permitFileUrl))
                            {
                                <span class="text-muted">No file uploaded</span>
                            }
                            else
                            {
                                <a href="@permitFileUrl" target="_blank" rel="noopener noreferrer">View Business or Mayor's Permit / PEZA Certificate Attachment</a>
                            }
                        </dd>
                        <dd class="col-sm-12 col-lg">
                            <input type="checkbox" class="form-check-input remarks-check-box" name="est_bus_perm_ck" id="est_bus_perm_ck" value="Approved" checked />
                            <input type="text" class="form-control mb-3 input-remarks" id="est_bus_perm_input" name="est_bus_perm_input" disabled />
                        </dd>
                    </div>
                    <hr class="row mb-3" />
                    <div class="row gap-3">
                        <dt class="col-sm-12 col-lg">Valid National ID Number:</dt>
                        <dd class="col-sm-12 col-lg">@FormatString(register?.EstOwnerValidIDNumber)</dd>
                        <dd class="col-sm-12 col-lg">
                            <input type="checkbox" class="form-check-input remarks-check-box" name="est_valid_number_ck" id="est_valid_number_ck" value="Approved" checked />
                            <input type="text" class="form-control mb-3 input-remarks" id="est_valid_number_input" name="est_valid_number_input" disabled />
                        </dd>
                    </div>
                    <hr class="row mb-3" />
                    <div class="row gap-3">
                        <dt class="col-sm-12 col-lg">Valid National Government ID Issued Date:</dt>
                        <dd class="col-sm-12 col-lg">@FormatDate(register?.EstOwnerValidIDDateIssued)</dd>
                        <dd class="col-sm-12 col-lg">
                            <input type="checkbox" class="form-check-input remarks-check-box" name="est_valid_dateiss_ck" id="est_valid_dateiss_ck" value="Approved" checked />
                            <input type="text" class="form-control mb-3 input-remarks" id="est_valid_dateiss_input" name="est_valid_dateiss_input" disabled />
                        </dd>
                    </div>
                    <hr class="row mb-3" />
                    <div class="row gap-3">
                        <dt class="col-sm-12 col-lg">Valid National Government ID Validity:</dt>
                        <dd class="col-sm-12 col-lg">@FormatDate(register?.EstOwnerValidIDDateExpire)</dd>
                        <dd class="col-sm-12 col-lg">
                            <input type="checkbox" class="form-check-input remarks-check-box" name="est_valid_validity_ck" id="est_valid_validity_ck" value="Approved" checked />
                            <input type="text" class="form-control mb-3 input-remarks" id="est_valid_validity_input" name="est_valid_validity_input" disabled />
                        </dd>
                    </div>
                    <hr class="row mb-3" />
                    <div class="row gap-3">
                        <dt class="col-sm-12 col-lg">Valid ID Attachment:</dt>
                        <dd class="col-sm-12 col-lg">
                            @{
                                var validIdUrl = BuildAttachmentUrl(register?.Id, "valid_id", register?.EstOwnerValidIDFile);
                            }
                            @if (string.IsNullOrEmpty(validIdUrl))
                            {
                                <span class="text-muted">No file uploaded</span>
                            }
                            else
                            {
                                <a href="@validIdUrl" target="_blank" rel="noopener noreferrer">View Valid ID</a>
                            }
                        </dd>
                        <dd class="col-sm-12 col-lg">
                            <input type="checkbox" class="form-check-input remarks-check-box" name="est_termrep_ck" id="est_termrep_ck" value="Approved" checked />
                            <input type="text" class="form-control mb-3 input-remarks" id="est_termrep_input" name="est_termrep_input" disabled />
                        </dd>
                    </div>
                    <hr class="row mb-3" />
                    <div class="row gap-3">
                        <dt class="col-sm-12 col-lg">Valid National ID Number:</dt>
                        <dd class="col-sm-12 col-lg">@FormatString(register?.EstOwnerValidIDNumber)</dd>
                        <dd class="col-sm-12 col-lg">
                            <input type="checkbox" class="form-check-input remarks-check-box" name="est_valid_number_ck" id="est_valid_number_ck" value="Approved" checked />
                            <input type="text" class="form-control mb-3 input-remarks" id="est_valid_number_input" name="est_valid_number_input" disabled />
                        </dd>
                    </div>
                    <hr class="row mb-3" />
                    <div class="row gap-3">
                        <dt class="col-sm-12 col-lg">Valid National ID Number:</dt>
                        <dd class="col-sm-12 col-lg">@FormatString(register?.EstOwnerValidIDNumber)</dd>
                        <dd class="col-sm-12 col-lg">
                            <input type="checkbox" class="form-check-input remarks-check-box" name="est_valid_number_ck" id="est_valid_number_ck" value="Approved" checked />
                            <input type="text" class="form-control mb-3 input-remarks" id="est_valid_number_input" name="est_valid_number_input" disabled />
                        </dd>
                    </div>
                </dl>
            </div>
        </div>
        <div class="tab-pane fade" id="action" role="tabpanel" aria-labelledby="action-ap-tab">
            <h3 class="mt-3">Action</h3>
            <div class="row">
                <div class="p-4 bg-light">
                    <div class="row mb-4">
                        <div class="col-lg-12 col-sm-12">
                            <select asp-for="Register.EstStatus" class="form-control" id="recom" required>
                                <option selected disabled value="">Select recommendation below (required)</option>
                                <option value="@SD.StatusForApproval">@SD.StatusForApproval</option>
                                <option value="@SD.StatusForReapplication">@SD.StatusForReapplication</option>
                                <option value="@SD.StatusDuplicate">@SD.StatusDuplicate</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-lg-12 col-sm-12">
                            <label>Remarks <span class="text-muted fw-lighter">(optional)</span></label>
                            <textarea asp-for="Register.EstEvalRemarks" class="form-control" rows="6" placeholder="" maxlength="255"></textarea>
                        </div>
                    </div>
                    <button type="submit" id="submit" class="btn btn-primary bg-gradient text-white btn-block ladda-button">Proceed to Recommendation</button>
                </div>
            </div>
        </div>
    </div>
</form>
@section Scripts {
    <script src="~/js/Evaluator/review.js"></script>
}