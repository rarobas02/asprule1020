@model RegisterVM

@{
    ViewData["Title"] = "For Updating Registration Details";
    var register = Model?.Register;
    string FormatString(string? value) => string.IsNullOrWhiteSpace(value) ? "N/A" : value;
    string FormatDate(DateTime? date) => date?.ToString("MMMM dd, yyyy") ?? "N/A";
    string FormatBool(bool? value) => value switch { true => "Yes", false => "No", _ => "N/A" };
    string FormatNumber(int? value) => value.HasValue ? value.Value.ToString("N0") : "N/A";
    string FormatList(List<string>? values) => values is { Count: > 0 } ? string.Join(", ", values) : "N/A";
    string BuildAttachmentUrl(Guid? registerId, string type, string? storedPath) =>
        !registerId.HasValue || string.IsNullOrWhiteSpace(storedPath)
            ? string.Empty
            : Url.Action("ViewAttachment", "Evaluator", new { area = "Admin", id = registerId.Value, type }) ?? string.Empty;
}

<ul class="nav nav-tabs" id="action_tab" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active d-flex align-self-start align-items-center" id="registration_details-ap-tab"
                data-bs-toggle="tab" data-bs-target="#registration_details" type="button" role="tab"
                aria-controls="registration_details" aria-selected="true">
            <i class="fa-solid fa-arrow-trend-up fa-xs me-1"></i>
            Registration Details<span class="badge badge-pill badge-danger ms-2 registration_details-badge"></span>
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link d-flex align-self-start align-items-center" id="action-ap-tab"
                data-bs-toggle="tab" data-bs-target="#action" type="button" role="tab"
                aria-controls="action" aria-selected="false">
            <i class="fa-solid fa-arrow-trend-up fa-xs me-1"></i>
            Action<span class="badge badge-pill badge-danger ms-2 action-badge"></span>
        </button>
    </li>
</ul>
